{
  "expo": {
    "name": "Daily Throwdown",
    "slug": "daily-throwdown",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dailythrowdown",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#090511"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dailythrowdown.app"
    },
    "android": {
      "package": "com.dailythrowdown.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#090511"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#e879f9"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "https://voyomzwngveliynokfmp.supabase.co",
      "supabaseAnonKey": "sb_publishable_6dExJuanfOzfZgIyyJc6YA_ndEWMtjw"
    }
  }
}
